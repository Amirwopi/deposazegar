# ===============================
# deposazegar.com Production .htaccess
# Static HTML / Apache / LiteSpeed / cPanel
# ===============================

DirectoryIndex index.html
Options -Indexes

# -------------------------------
# Force HTTPS + non-www
# Canonical: https://deposazegar.com/
# -------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.deposazegar\.com$ [NC,OR]
  RewriteCond %{HTTP_HOST} ^(?:www\.)?deposazegar\.ir$ [NC]
  RewriteRule ^ https://deposazegar.com%{REQUEST_URI} [R=301,L,NE]

  # -------------------------------
  # Redirect /index.html → / (only direct requests, not DirectoryIndex)
  # Prevents duplicate-content from index.html and root URL
  # -------------------------------
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
  RewriteRule ^index\.html$ / [R=301,L,NE]

  # -------------------------------
  # 301 redirects: old Persian slugs → new clean URLs
  # -------------------------------
  RewriteRule ^ejare-anbar-containeri-tehran\.html$ /container-storage [R=301,L,NE]
  RewriteRule ^depo-lavazem-khaneh\.html$ /home-appliances-storage [R=301,L,NE]
  RewriteRule ^ejare-anbar-vasayel-sherkat\.html$ /commercial-storage [R=301,L,NE]
  RewriteRule ^gheymat-ejare-anbar-tehran\.html$ /pricing [R=301,L,NE]
  RewriteRule ^ejare-anbar-gharb-tehran\.html$ /location/west-tehran [R=301,L,NE]
  RewriteRule ^ejare-anbar-shargh-tehran\.html$ /location/east-tehran [R=301,L,NE]
  RewriteRule ^ejare-anbar-jonoub-tehran\.html$ /location/south-tehran [R=301,L,NE]

  # -------------------------------
  # Blanket 301: strip .html from ALL direct requests → clean URLs
  # Catches any *.html URL typed/linked directly and redirects to clean version
  # Uses THE_REQUEST so internal rewrites (line below) are not affected
  # -------------------------------
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)\.html\ HTTP/
  RewriteRule ^ /%1 [R=301,L,NE]

  # -------------------------------
  # Clean URL rewrite: serve .html without extension
  # -------------------------------
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)/?$ $1.html [L]
</IfModule>

# -------------------------------
# MIME Types
# -------------------------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType application/xml .xml
</IfModule>

# -------------------------------
# Compression
# -------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# -------------------------------
# Browser Cache
# -------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  ExpiresByType font/woff2 "access plus 1 year"

  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType text/plain "access plus 1 day"
</IfModule>

# -------------------------------
# Cache-Control Headers
# -------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(?:webp|jpe?g|png|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:xml|txt)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# -------------------------------
# Protect hidden/system files
# -------------------------------
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
